<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header Hijau Solid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#388E3C"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/ivLogoDaerahDinamis"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:visibility="gone"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tvCompleteData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/complete_vehicle_data"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Area Upload Foto (Bisa Banyak Foto) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardUploadImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <HorizontalScrollView
                        android:id="@+id/scrollFoto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:id="@+id/containerFoto"
                            android:layout_width="wrap_content"
                            android:layout_height="120dp"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="#F5F5F5"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_camera"
                            app:tint="#388E3C" />

                        <TextView
                            android:id="@+id/tvAddPhoto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_photo"
                            android:textColor="#388E3C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Input Fields dengan Border Bawah -->
            <EditText
                android:id="@+id/etNamaKendaraan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/vehicle_name"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/edit_text"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvVehicleTypeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_type"
                android:textSize="14sp"
                android:textColor="#424242"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgTipeKendaraan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbMobil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/car"
                    android:checked="true"
                    android:layout_marginEnd="20dp"/>

                <RadioButton
                    android:id="@+id/rbMotor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/motorcycle"
                    android:layout_marginEnd="20dp"/>

                <RadioButton
                    android:id="@+id/rbLainnya"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/others" />
            </RadioGroup>

            <EditText
                android:id="@+id/etMerek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/brand"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/edit_text"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etTahun"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/year"
                    android:padding="12dp"
                    android:inputType="number"
                    android:background="@android:drawable/edit_text"
                    android:textSize="14sp"/>

                <View
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <EditText
                    android:id="@+id/etHarga"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:hint="@string/price"
                    android:padding="12dp"
                    android:inputType="number"
                    android:background="@android:drawable/edit_text"
                    android:textSize="14sp"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etNoTelpon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/phone_hint"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:inputType="phone"
                android:background="@android:drawable/edit_text"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etDeskripsi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/description"
                android:padding="12dp"
                android:layout_marginBottom="32dp"
                android:background="@android:drawable/edit_text"
                android:textSize="14sp"/>

            <!-- Tombol Pasang Iklan Hijau -->
            <Button
                android:id="@+id/btnUpload"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/post_ad"
                android:backgroundTint="#388E3C"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                app:cornerRadius="4dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
