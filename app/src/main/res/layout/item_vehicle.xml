<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Wadah Foto: Akan diisi foto-foto secara Horizontal (Small Icons) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/containerFotoBeli"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvVehicleName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Nama Kendaraan"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <!-- Badge High Risk (Default GONE) -->
            <TextView
                android:id="@+id/tvFraudBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH RISK / SUSPICIOUS"
                android:textColor="#FFFFFF"
                android:background="#D32F2F"
                android:padding="4dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </LinearLayout>

        <RatingBar
            android:id="@+id/ratingBarSmall"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:rating="4.5"
            android:progressTint="#FFD700" />

        <TextView
            android:id="@+id/tvVehiclePrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harga"
            android:textColor="#388E3C"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvVehicleYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tahun"
                android:textSize="14sp"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/tvVehicleType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipe"
                android:textSize="14sp"
                android:background="#E8F5E9"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:textColor="#2E7D32"/>
        </LinearLayout>

        <!-- Tambahkan Deskripsi/Spek di sini -->
        <TextView
            android:id="@+id/tvVehicleDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Keterangan barang..."
            android:textSize="14sp"
            android:textColor="#666666"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/btnHubungiPenjual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/contact_seller"
            android:backgroundTint="#25D366"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
