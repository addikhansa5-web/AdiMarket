<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sales_analysis_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:textColor="#333333"/>

    <!-- Placeholder untuk Grafik (Menggunakan View Sederhana sebagai Bar Chart) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="bottom">

        <View android:layout_width="30dp" android:layout_height="100dp" android:background="#4CAF50" android:layout_margin="8dp"/>
        <View android:layout_width="30dp" android:layout_height="150dp" android:background="#4CAF50" android:layout_margin="8dp"/>
        <View android:layout_width="30dp" android:layout_height="120dp" android:background="#4CAF50" android:layout_margin="8dp"/>
        <View android:layout_width="30dp" android:layout_height="200dp" android:background="#4CAF50" android:layout_margin="8dp"/>
        <View android:layout_width="30dp" android:layout_height="180dp" android:background="#4CAF50" android:layout_margin="8dp"/>
        <View android:layout_width="30dp" android:layout_height="250dp" android:background="#4CAF50" android:layout_margin="8dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grafik menunjukkan kenaikan jumlah iklan &amp; transaksi bulan ini."
        android:layout_marginTop="16dp"
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"/>

    <Button
        android:id="@+id/btnBackSales"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/back"
        android:backgroundTint="#2E7D32"/>

</LinearLayout>