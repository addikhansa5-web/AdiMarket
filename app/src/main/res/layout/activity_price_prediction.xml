<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etTahun"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tahun Kendaraan (Contoh: 2020)"
        android:inputType="number" />

    <EditText
        android:id="@+id/etKilometer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Kilometer"
        android:inputType="number" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kondisi:"
        android:layout_marginTop="8dp"/>

    <Spinner
        android:id="@+id/spKondisi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jenis Kendaraan:"
        android:layout_marginTop="8dp"/>

    <Spinner
        android:id="@+id/spJenisKendaraan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/btnPredict"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Prediksi Harga" />

    <TextView
        android:id="@+id/tvPredictedPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>